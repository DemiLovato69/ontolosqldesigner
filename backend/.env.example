APP_NAME=sql-designer
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000#change to "http://localhost:8080" for docker

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1#change to "mysql" for docker
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

BROADCAST_CONNECTION=reverb
CACHE_DRIVER=database
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=cookie
SESSION_LIFETIME=120

REVERB_APP_ID=snydiagram
REVERB_APP_KEY=snydiagram-key
REVERB_APP_SECRET=snydiagram-secret
REVERB_HOST=localhost
REVERB_PORT=6001
REVERB_SCHEME=http

REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=6001

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
# Dev: use nginx port (8080). Prod: use 443.
VITE_REVERB_PORT=8080
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

SESSION_DOMAIN=localhost
SANCTUM_STATEFUL_DOMAINS=localhost:8000

MAIL_MAILER=
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME=

ADMIN_PASSWORD=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=


INDEXNOW_KEY=

