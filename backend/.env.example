APP_NAME=sql-designer
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000#change to "http://localhost:8080" for docker

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1#change to "mysql" for docker
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

BROADCAST_CONNECTION=reverb
CACHE_DRIVER=database
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=cookie
SESSION_LIFETIME=120

REVERB_APP_ID=snydiagram
REVERB_APP_KEY=snydiagram-key
REVERB_APP_SECRET=snydiagram-secret
REVERB_HOST=localhost
REVERB_PORT=6001
REVERB_SCHEME=http
REVERB_INTERNAL_HOST=reverb
REVERB_INTERNAL_PORT=6001
REVERB_INTERNAL_SCHEME=http

REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=6001

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
# Dev: use nginx port (8080). Prod: use 443.
VITE_REVERB_PORT=8080
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

SESSION_DOMAIN=localhost
SANCTUM_STATEFUL_DOMAINS=localhost:8000

MAIL_MAILER=log
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@localhost
MAIL_FROM_NAME="${APP_NAME}"

ADMIN_PASSWORD=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_ALLOWED_DOMAIN=company.com

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=


INDEXNOW_KEY=

GOOGLE_INDEXING_SA_KEY_PATH=

# Foundry Platform integration (read-only, delegated per-user OAuth).
# Hybrid host model: diagram owners may enter any host, but connecting/querying
# requires either an admin-configured host (FOUNDRY_HOSTS_JSON) or custom hosts
# explicitly enabled with a custom-host OAuth client.
FOUNDRY_ALLOW_CUSTOM_HOSTS=false
FOUNDRY_ALLOW_INSECURE_HOSTS=false
# Allow connecting a host by pasting a Foundry token (works without an OAuth client).
FOUNDRY_ALLOW_TOKEN_AUTH=true
# OAuth scopes requested at connect time. Browsing spaces/folders/ontologies and
# reading datasets requires the corresponding Platform read scopes, and the
# Foundry OAuth client must be granted them. If listing returns
# "foundry_access_denied", the connection is missing scopes — set the full list
# here and reconnect, e.g.:
#   "api:read-data api:ontologies-read api:datasets-read api:filesystem-read offline_access"
# (Exact scope names depend on your Foundry stack/enrollment.)
FOUNDRY_DEFAULT_SCOPES="api:read-data offline_access"
# Defaults to "${APP_URL}/api/v1/foundry/oauth/callback"; must be registered on each Foundry OAuth client.
FOUNDRY_REDIRECT_URI=
FOUNDRY_OAUTH_STATE_TTL_SECONDS=600
# Per-host admin OAuth client map keyed by normalized host url, e.g.
# {"https://example.palantirfoundry.com":{"client_id":"...","client_secret":null,"display_name":"Example"}}
FOUNDRY_HOSTS_JSON={}
# Used only when FOUNDRY_ALLOW_CUSTOM_HOSTS=true for owner-entered hosts.
FOUNDRY_CUSTOM_HOST_CLIENT_ID=
FOUNDRY_CUSTOM_HOST_CLIENT_SECRET=
# Node bridge for @osdk/foundry (defaults work in Docker).
FOUNDRY_RUNTIME_NODE=node
FOUNDRY_RUNTIME_SCRIPT=
FOUNDRY_RUNTIME_TIMEOUT=30
# Diagram agent (Foundry AIP OpenAI-compatible LLM proxy). Enabled by default;
# still requires AIP enabled on the stack and a model added at /admin/foundry.
FOUNDRY_LLM_ENABLED=true
FOUNDRY_LLM_ENDPOINT=/api/v2/llm/proxy/openai/v1/chat/completions
FOUNDRY_LLM_TIMEOUT_SECONDS=60
FOUNDRY_LLM_MAX_CONTEXT_BYTES=250000
FOUNDRY_LLM_MAX_OUTPUT_TOKENS=4000
FOUNDRY_LLM_TEMPERATURE=0.1
# Persist agent prompts/responses (encrypted) for collaborator-visible history.
FOUNDRY_LLM_STORE_PROMPTS=true
