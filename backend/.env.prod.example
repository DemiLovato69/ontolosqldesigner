APP_NAME=snydiagram
APP_ENV=production
# Generate with: docker compose -f docker-compose.prod.yml exec php php artisan key:generate --show
APP_KEY=
APP_DEBUG=false
APP_URL=https://sql-designer.com

LOG_CHANNEL=stack
LOG_LEVEL=error

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=snydiagram
DB_USERNAME=dbuser
#Needs to be setup by hand when first deploying
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

CACHE_DRIVER=database
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_DOMAIN=sql-designer.com
# Set to true once HTTPS is configured.
SESSION_SECURE_COOKIE=false

SANCTUM_STATEFUL_DOMAINS=sql-designer.com

MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
#Needs to be setup by hand when first deploying
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME=